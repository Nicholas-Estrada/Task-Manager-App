PORT=5000
MONGO_URI=mongodb://localhost:27017/tempus
    # OR use MongoDB Atlas:
    # MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/tempus

FRONTEND_URL=http://localhost:3000

# Generate VAPID keys once with:  node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=your_public_vapid_key_here
VAPID_PRIVATE_KEY=your_private_vapid_key_here
VAPID_EMAIL=mailto:you@yourdomain.com